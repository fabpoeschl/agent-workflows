#!/bin/sh
set -e

AGENTS_DIR="${AGENTS_DIR:-$HOME/.agents}"

if [ ! -d "$AGENTS_DIR" ]; then
  echo "Error: $AGENTS_DIR does not exist. Clone the agents repo there or set AGENTS_DIR." >&2
  exit 1
fi

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: not in a git repository." >&2
  exit 1
fi

# Resolve project name from the main worktree root (works for linked worktrees too)
main_root=$(git worktree list | head -1 | awk '{print $1}')
project_name=$(basename "$main_root")

# Symlink .agents, AGENTS.md and CLAUDE.md to project root
ln -sfn "$AGENTS_DIR" .agents
ln -sf "$AGENTS_DIR/AGENTS.md" AGENTS.md
ln -sf "$AGENTS_DIR/AGENTS.md" CLAUDE.md

# Scaffold doc/ with project-specific directories and context
mkdir -p doc "$AGENTS_DIR/projects/$project_name/specs"
ln -sfn "../.agents/projects/$project_name/specs" doc/specs

if [ ! -f "$AGENTS_DIR/projects/$project_name/context.md" ]; then
  cat > "$AGENTS_DIR/projects/$project_name/context.md" <<'EOF'
# Project Context

Cross-cutting rules: see `.agents/conventions.md`.

## Overview
<!-- Brief description of this project -->

## Tech Stack
<!-- Languages, frameworks, and key dependencies -->

## Architecture
<!-- High-level architecture and key patterns -->

## Development
<!-- How to build, test, and run the project -->
EOF
  echo "Created .agents/projects/$project_name/context.md — fill in your project details"
fi
ln -sf "../.agents/projects/$project_name/context.md" doc/context.md

if [ ! -f "$AGENTS_DIR/projects/$project_name/config.yaml" ]; then
  cat > "$AGENTS_DIR/projects/$project_name/config.yaml" <<'EOF'
# Machine-readable project config consumed by workflows / pi-mono.
# Add only fields the agent or runtime needs to parse; prose stays in context.md.

test_dirs: []   # paths the spec workflow may write tests to, e.g. [test/, spec/]
EOF
  echo "Created .agents/projects/$project_name/config.yaml — fill in test_dirs etc."
fi
ln -sf "../.agents/projects/$project_name/config.yaml" doc/config.yaml

# Populate .claude/commands for Claude Code (pi-mono reads ~/.agents/skills directly)
# For flat .md skills: symlink the file. For pi-format skill dirs: extract the SKILL.md body.
mkdir -p .claude/commands
for skill in "$AGENTS_DIR/skills"/*; do
  name=$(basename "$skill")
  if [ -d "$skill" ] && [ -f "$skill/SKILL.md" ]; then
    awk '/^---/{if(++n==2){body=1;next}} body' "$skill/SKILL.md" > ".claude/commands/$name.md"
  elif [ -f "$skill" ]; then
    ln -sf "$skill" ".claude/commands/$name"
  fi
done

# Install post-checkout hook in the main worktree so new worktrees auto-link
hook_dir="$main_root/.git/hooks"
hook_file="$hook_dir/post-checkout"
mkdir -p "$hook_dir"

if [ ! -f "$hook_file" ]; then
  cat > "$hook_file" <<'HOOK'
#!/bin/sh
# Auto-link agents repo for new worktrees
[ ! -L ".agents" ] && [ -f "${AGENTS_DIR:-$HOME/.agents}/link" ] && "${AGENTS_DIR:-$HOME/.agents}/link"
HOOK
  chmod +x "$hook_file"
  echo "Installed post-checkout hook — new worktrees will auto-link"
elif ! grep -q "Auto-link agents" "$hook_file" 2>/dev/null; then
  echo "Warning: post-checkout hook already exists at $hook_file and was not modified."
  echo "Add this line to auto-link new worktrees:"
  printf '  [ ! -L ".agents" ] && [ -f "${AGENTS_DIR:-$HOME/.agents}/link" ] && "${AGENTS_DIR:-$HOME/.agents}/link"\n'
fi

# Ensure generated files are in the project's .gitignore
for entry in .agents AGENTS.md CLAUDE.md doc/context.md doc/config.yaml doc/specs .claude/commands; do
  if ! grep -qxF "$entry" .gitignore 2>/dev/null; then
    echo "$entry" >> .gitignore
  fi
done

echo "Done: $project_name → $AGENTS_DIR"
